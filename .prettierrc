{
  "arrowParens": "always",
  "bracketSpacing": true,
  "tabWidth": 2,
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "singleAttributePerLine": true,
  "bracketSameLine": false,
  "jsxSingleQuote": true,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.config.ts",
      "options": {
        "parser": "typescript"
      }
    }
  ]
}
