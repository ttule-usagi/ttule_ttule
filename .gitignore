# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
pnpm-lock.yaml       
setup-pnpm.js

# 로그 파일 확장
logs
*.log

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Editor settings
.vscode/*
!.vscode/extensions.json  # 팀원들에게 추천 익스텐션을 공유하고 싶을 때만 예외 처리
.idea/                    # WebStorm 등 JetBrains 도구 사용 시
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?                     # Vim 임시 파일

# OS specific
Thumbs.db                 # Windows 이미지 캐시